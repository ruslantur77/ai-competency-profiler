# =============================================================================
# Competency System - Environment Configuration
# =============================================================================

# Application Settings
LOG_LEVEL=info
DEBUG=false
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=app
DB_PASS=app

# LLM Configuration (OpenRouter)
API_KEY=sk-or-v1-your-api-key-here
BASE_URL=https://openrouter.ai/api/v1
MODEL=openai/gpt-oss-20b:free
VACANCY_PROMPT_VERSION=v1
TASK_PROMPT_VERSION=v1
CODE_PROMPT_VERSION=v1
LLM_MAX_PARALLEL_REQUESTS=4
LLM_STAGE_TIMEOUT_SECONDS=45
LLM_MAX_SUGGESTED_NEW_PER_STAGE=5
LLM_REASONING_MAX_TOKENS=0
LLM_QUEUE_BACKEND=inmemory

# Celery + Redis (for durable LLM queue when LLM_QUEUE_BACKEND=celery)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=password
CELERY_QUEUE_NAME=llm_jobs
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_RETRY_ATTEMPTS=3
CELERY_RETRY_BACKOFF_SECONDS=2
CELERY_RETRY_BACKOFF_MAX_SECONDS=30

# Alternative models (uncomment to use):
# MODEL=deepseek/deepseek-chat:free
# MODEL=meta-llama/llama-3.1-405b-instruct:free

# External Testing System
TESTING_SYSTEM_BASE_URL=http://localhost:9000
TESTING_SYSTEM_API_TOKEN=

# Airflow Configuration
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_IMAGE_NAME=competency-system/airflow:latest
AIRFLOW__CORE__EXECUTOR=DockerExecutor
AIRFLOW__CORE__DAGS_FOLDER=/app/src/competency_system/presentation/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs

# Security (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme
