# =============================================================================
# Competency System - Environment Configuration (Example)
# =============================================================================

# Уровень логирования приложения: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO
# Включает debug-режим FastAPI/Pydantic (только для локальной разработки).
DEBUG=false
# Разрешенные CORS origins через запятую.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Хост PostgreSQL для backend-приложения.
DB_HOST=postgres
# Порт PostgreSQL для backend-приложения.
DB_PORT=5432
# Имя БД backend-приложения.
DB_NAME=competency_db
# Пользователь БД backend-приложения.
DB_USER=postgres
# Пароль пользователя БД backend-приложения.
DB_PASS=password

# API-ключ LLM-провайдера (OpenRouter/OpenAI-compatible).
API_KEY=your-api-key
# Базовый URL LLM API.
BASE_URL=https://openrouter.ai/api/v1
# Идентификатор модели LLM.
MODEL=openai/gpt-oss-20b
# Таймаут одного LLM-запроса в секундах.
LLM_TIMEOUT_SECONDS=30
# Количество ретраев LLM-запросов при ошибках.
LLM_RETRY_ATTEMPTS=3
# Максимум параллельных LLM-запросов.
LLM_MAX_PARALLEL_REQUESTS=4
# Таймаут этапа LLM-пайплайна в секундах.
LLM_STAGE_TIMEOUT_SECONDS=45
# Версия промпта извлечения графа вакансии.
VACANCY_PROMPT_VERSION=v1
# Версия промпта маппинга задач.
TASK_PROMPT_VERSION=v1
# Версия промпта code-assessment.
CODE_PROMPT_VERSION=v1
# Лимит новых предложенных компетенций на этап.
LLM_MAX_SUGGESTED_NEW_PER_STAGE=5
# Лимит reasoning токенов (0 = без явного ограничения).
LLM_REASONING_MAX_TOKENS=0
# Бэкенд очереди LLM-задач: inmemory | celery.
LLM_QUEUE_BACKEND=celery

# Хост Redis для Celery/очередей.
REDIS_HOST=redis
# Порт Redis.
REDIS_PORT=6379
# Пароль Redis (должен совпадать с redis-сервисом).
REDIS_PASSWORD=password
# Имя Celery-очереди для LLM задач.
CELERY_QUEUE_NAME=llm_jobs
# Время хранения Celery result backend (секунды).
CELERY_RESULT_EXPIRES_SECONDS=86400
# Количество ретраев Celery-задачи.
CELERY_RETRY_ATTEMPTS=3
# Начальная задержка backoff для Celery-ретраев (секунды).
CELERY_RETRY_BACKOFF_SECONDS=2
# Максимальная задержка backoff для Celery-ретраев (секунды).
CELERY_RETRY_BACKOFF_MAX_SECONDS=30

# Base URL внешней тестовой системы.
TESTING_SYSTEM_BASE_URL=http://localhost:9000
# Токен доступа к внешней тестовой системе.
TESTING_SYSTEM_API_TOKEN=
# Shared secret для верификации webhook `X-Webhook-Secret`.
TESTING_SYSTEM_WEBHOOK_SECRET=change-me

# Логин администратора Airflow UI.
AIRFLOW_USERNAME=admin
# Пароль администратора Airflow UI.
AIRFLOW_PASSWORD=admin
# Имя/тег Docker-образа Airflow.
AIRFLOW_IMAGE_NAME=competency-system/airflow:latest
# Executor Airflow (например: LocalExecutor, DockerExecutor).
AIRFLOW__CORE__EXECUTOR=LocalExecutor
# Путь к DAG-файлам внутри контейнера Airflow.
AIRFLOW__CORE__DAGS_FOLDER=/app/src/competency_system/presentation/airflow/dags
# Загружать ли demo DAG-ы Airflow.
AIRFLOW__CORE__LOAD_EXAMPLES=False
# Директория логов Airflow внутри контейнера.
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
# Секрет веб-сервера Airflow (сгенерировать для non-dev).
AIRFLOW__WEBSERVER__SECRET_KEY=change-me
# Fernet key Airflow для шифрования connections/variables.
AIRFLOW__CORE__FERNET_KEY=change-me
# SQLAlchemy URL metadata-базы Airflow.
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:password@postgres/airflow

# Алгоритм подписи JWT.
JWT_ALGORITHM=HS256
# TTL access token в минутах.
ACCESS_TOKEN_EXPIRE_MINUTES=15
# TTL refresh token в днях.
REFRESH_TOKEN_EXPIRE_DAYS=7
# Секрет подписи JWT/токенов (обязателен в проде).
SECRET_KEY=change-me
# Secure-флаг auth cookie (true для HTTPS).
AUTH_COOKIE_SECURE=false
# SameSite-политика auth cookie: lax | strict | none.
AUTH_COOKIE_SAMESITE=lax
# Email bootstrap-админа, создаваемого при инициализации.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# Пароль bootstrap-админа.
BOOTSTRAP_ADMIN_PASSWORD=change-me

# Пользователь системной БД PostgreSQL контейнера (для Airflow metadata).
POSTGRES_USER=airflow
# Имя системной БД PostgreSQL контейнера (для Airflow metadata).
POSTGRES_DB=airflow
# Пароль системного пользователя PostgreSQL контейнера.
POSTGRES_PASSWORD=password

# Путь к docker.sock на хосте (укажите rootless/rootful путь под вашу среду).
DOCKER_SOCKET=/run/user/1000/docker.sock
