# =============================================================================
# Competency System - Environment Configuration (Source of Truth)
# =============================================================================
# Правило: при конфликте документации и env-файлов источником истины является этот файл.

# -----------------------------------------------------------------------------
# Application settings (consumer: backend/src/.../settings.py)
# -----------------------------------------------------------------------------

# [app|required] Уровень логирования: DEBUG | INFO | WARNING | ERROR | CRITICAL.
LOG_LEVEL=INFO
# [app|optional] Локальный debug-режим FastAPI/Pydantic.
DEBUG=false
# [app|optional] Имя окружения приложения (например: local | staging | production).
ENVIRONMENT=local
# [app|optional] CORS origins через запятую.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# [app|required] Параметры подключения backend к PostgreSQL.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=competency_db
DB_USER=postgres
DB_PASS=password

# [app|required] Параметры LLM-провайдера (OpenAI-compatible API).
API_KEY=your-api-key
BASE_URL=https://openrouter.ai/api/v1
MODEL=openai/gpt-oss-20b
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=3
LLM_MAX_PARALLEL_REQUESTS=4
LLM_STAGE_TIMEOUT_SECONDS=45
VACANCY_PROMPT_VERSION=v1
TASK_PROMPT_VERSION=v1
CODE_PROMPT_VERSION=v1
LLM_MAX_SUGGESTED_NEW_PER_STAGE=5
LLM_REASONING_MAX_TOKENS=0
# [app|optional] Режим очереди LLM: inmemory | celery.
LLM_QUEUE_BACKEND=celery

# [app|required при celery-режиме] Redis/Celery параметры, используемые приложением.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password
CELERY_QUEUE_NAME=llm_jobs
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_RETRY_ATTEMPTS=3
CELERY_RETRY_BACKOFF_SECONDS=2
CELERY_RETRY_BACKOFF_MAX_SECONDS=30

# [app|optional] Интеграция внешней тестовой системы.
TESTING_SYSTEM_BASE_URL=http://localhost:9000
TESTING_SYSTEM_API_TOKEN=
TESTING_SYSTEM_WEBHOOK_SECRET=change-me

# [app|required] Настройки аутентификации и bootstrap-админа.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
SECRET_KEY=change-me
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me

# -----------------------------------------------------------------------------
# Runtime/Infrastructure settings (consumer: docker-compose / Airflow / контейнеры)
# -----------------------------------------------------------------------------

# [runtime|optional] Тег образа Airflow (override для compose).
AIRFLOW_IMAGE_NAME=competency-system/airflow:latest
# [runtime|optional] Образ backend, который запускается из Airflow DockerOperator для task_sync.
TASK_SYNC_IMAGE=competency-system/api:latest
# [runtime|required для DockerOperator] Docker network для контейнеров task_sync (должна видеть postgres/redis/testing-system).
AIRFLOW_DOCKER_NETWORK=backend_default

# [runtime|required] Базовые параметры Airflow.
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__PARALLELISM=1
AIRFLOW__CORE__MAX_ACTIVE_TASKS_PER_DAG=1
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1
AIRFLOW__CORE__DAGS_FOLDER=/app/src/competency_system/presentation/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__SCHEDULER__PARSING_PROCESSES=1
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=30
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__CORE__FERNET_KEY=change-me
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:password@postgres/airflow
AIRFLOW__WEBSERVER__BASE_URL=http://example.com/airflow

# [runtime|required] Airflow API auth (используется внутри Airflow-контейнеров).
AIRFLOW__API_AUTH__JWT_SECRET=secret
AIRFLOW__API_AUTH__JWT_ISSUER=airflow
AIRFLOW__API__SECRET_KEY=secret
AIRFLOW__API__BASE_URL=http://airflow-webserver:8080

# [runtime|optional] Тюнинг Celery worker (compose command line).
CELERY_WORKER_CONCURRENCY=2
CELERY_MAX_TASKS_PER_CHILD=100
CELERY_WORKER_EXTRA_FLAGS=--without-gossip --without-mingle --without-heartbeat

# [runtime|required] Системная metadata-БД PostgreSQL (Airflow).
POSTGRES_USER=airflow
POSTGRES_DB=airflow
POSTGRES_PASSWORD=password

# [runtime|required] Путь к docker.sock на хосте (rootless/rootful зависит от среды).
DOCKER_SOCKET=/run/user/1000/docker.sock
