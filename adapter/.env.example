# Адаптер
ADAPTER_PORT=8001

# Source (Kontest LMS)
SOURCE_BASE_URL=lms_url
SOURCE_API_TOKEN=your_lms_token_here

# Курсы для синка (CSV или JSON)
SOURCE_COURSE_IDS=1,2
# или SOURCE_COURSE_IDS=[1,2]

# Маппинг course_id -> vacancy_id (JSON)
COURSE_VACANCY_MAP={"1": "40000000-0000-0000-0000-000000000001"}

# Backend (наша система)
BACKEND_WEBHOOK_URL=http://backend:8000/api/v1/webhook/task-completed
BACKEND_WEBHOOK_SECRET=your_webhook_secret_here

# Поллинг
POLL_INTERVAL_SECONDS=3600
INITIAL_LOOKBACK_MINUTES=1440

# БД
DB_PATH=adapter_state.db

# Retry / DLQ
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_MIN_WAIT=2
WEBHOOK_RETRY_MAX_WAIT=60
DLQ_ENABLED=true
DLQ_MAX_ITEMS_PER_QUERY=100
BATCH_SIZE_OUTBOX=200

# Прочее
REQUEST_TIMEOUT_SECONDS=60
LOG_LEVEL=INFO