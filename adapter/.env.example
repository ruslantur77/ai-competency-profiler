# Testing system
# Базовый URL их API (без trailing slash)
LMS_BASE_URL=url

# Статичный Bearer-токен
LMS_API_TOKEN=your_lms_token_here

# Competency System
# URL webhook endpoint
OUR_WEBHOOK_URL=http://localhost:8000/api/v1/webhook/task-completed

# Секрет для заголовка X-Webhook-Secret (если включён)
OUR_WEBHOOK_SECRET=your_webhook_secret_here

# UUID вакансии в нашей системе, к которой привязываем результаты
TARGET_VACANCY_ID=123e4567-e89b-12d3-a456-426614174000

# Поллинг
# Интервал поллинга в секундах (3600 = 1 час)
POLL_INTERVAL_SECONDS=3600

# Сколько дней назад брать данные при первом запуске
INITIAL_LOOKBACK_DAYS=1

# База данных
DB_PATH=adapter_state.db

# Retry настройки (отправка в наш webhook)
# Максимум попыток отправки одного события
WEBHOOK_MAX_ATTEMPTS=5

# Начальная задержка retry в секундах
WEBHOOK_RETRY_MIN_WAIT=2

# Максимальная задержка retry в секундах  
WEBHOOK_RETRY_MAX_WAIT=60